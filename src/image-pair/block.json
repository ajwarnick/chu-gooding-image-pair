{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "chu-gooding/project-image-pair-two",
	"version": "0.1.0",
	"title": "C , G: Project Image Pair 2.0",
    "category": "chu-gooding-blocks",
    "icon": "format-image",
	"description": "Block for displaying two images side-by-side",
	"example": {},
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "full" ]
	},
	"attributes": {
